{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "auditooor.bug_bounty_oos_index.v1",
  "title": "BUG_BOUNTY OOS Index",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "workspace",
    "source_paths",
    "row_count",
    "rows",
    "index_hash",
    "high_confidence_threshold"
  ],
  "properties": {
    "schema": {
      "const": "auditooor.bug_bounty_oos_index.v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "workspace": {
      "type": "string"
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "row_count": {
      "type": "integer",
      "minimum": 0
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "clause_id",
          "section",
          "phrase",
          "semantic_tags",
          "source_path",
          "line_start"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "clause_id": {
            "type": "string"
          },
          "section": {
            "type": "string"
          },
          "phrase": {
            "type": "string"
          },
          "semantic_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_path": {
            "type": "string"
          },
          "line_start": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": true
      }
    },
    "index_hash": {
      "type": "string"
    },
    "high_confidence_threshold": {
      "type": "number"
    },
    "index_path": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
