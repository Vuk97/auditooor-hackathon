{
  "$id": "auditooor.lane_verdict.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attack_class": {
      "minLength": 1,
      "type": "string"
    },
    "candidate_id": {
      "minLength": 1,
      "type": "string"
    },
    "details": {
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "lane_id": {
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$",
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "record_id": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "auditooor.lane_verdict.v1",
      "type": "string"
    },
    "sequence": {
      "minimum": 1,
      "type": "integer"
    },
    "summary": {
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "type": "string"
    },
    "verdict": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "record_id",
    "timestamp",
    "lane_id",
    "sequence",
    "candidate_id",
    "attack_class",
    "verdict",
    "summary",
    "details",
    "evidence_refs",
    "metadata"
  ],
  "title": "Auditooor lane verdict record",
  "type": "object"
}
