import re
import sys
from pathlib import Path as _Path

sys.path.insert(0, str(_Path(__file__).resolve().parent.parent))
from _template_utils import is_vendored_or_test_contract, is_leaf_helper

from slither.detectors.abstract_detector import AbstractDetector, DetectorClassification

# FP precision: initializer-style findings (missing access control on an
# initializer, usable implementation contract, uninitialized state) are FALSE
# when the function is already guarded. A function carrying an
# `initializer`/`reinitializer` modifier, an access modifier
# (onlyOwner/onlyRole/onlyAdmin/onlyProxyAdmin/onlyGovernance), or living in a
# contract whose constructor calls `_disableInitializers()` is protected and
# must not be flagged. Defined here (not in the spec) so every
# name_match_missing_call detector inherits the guard on regeneration.
_INITIALIZER_MODIFIER_RE = re.compile(r"^(re)?initializer$", re.IGNORECASE)
_ACCESS_MODIFIER_RE = re.compile(
    r"^(onlyOwner|onlyRole|onlyAdmin|onlyProxyAdmin|onlyGovernance)$",
    re.IGNORECASE,
)


def _has_guard_modifier(f) -> bool:
    """True if f carries an initializer/reinitializer or access modifier."""
    for mod in getattr(f, "modifiers", []) or []:
        mname = getattr(mod, "name", "") or ""
        if _INITIALIZER_MODIFIER_RE.match(mname) or _ACCESS_MODIFIER_RE.match(mname):
            return True
    return False


def _constructor_disables_initializers(contract) -> bool:
    """True if the contract's constructor calls `_disableInitializers()`.

    Such a constructor renders the implementation un-initializable, defusing
    the 'usable implementation' / 'missing access control on initializer'
    finding class.
    """
    ctor = getattr(contract, "constructor", None)
    ctors = [ctor] if ctor is not None else []
    # Some Slither versions expose only constructors_declared
    for extra in getattr(contract, "constructors_declared", []) or []:
        if extra not in ctors:
            ctors.append(extra)
    for c in ctors:
        if c is None:
            continue
        for ic in getattr(c, "internal_calls", []) or []:
            callee = ic.function if hasattr(ic, "function") else ic
            cname = getattr(callee, "name", "") or ""
            if cname == "_disableInitializers":
                return True
        for sc in getattr(c, "solidity_calls", []) or []:
            scn = getattr(sc, "name", "") or str(sc)
            if "_disableInitializers" in scn:
                return True
    return False


class {CLASS_NAME}(AbstractDetector):
    ARGUMENT = "{ARGUMENT}"
    HELP = "{HELP}"
    IMPACT = DetectorClassification.{IMPACT}
    CONFIDENCE = DetectorClassification.{CONFIDENCE}
    WIKI = "https://github.com/Vuk97/auditooor/blob/main/reference/bug_patterns_observed.md"
    WIKI_TITLE = "{WIKI_TITLE}"
    WIKI_DESCRIPTION = "{WIKI_DESCRIPTION}"
    WIKI_EXPLOIT_SCENARIO = "{WIKI_EXPLOIT_SCENARIO}"
    WIKI_RECOMMENDATION = "{WIKI_RECOMMENDATION}"

    _FN_NAME_REGEX = re.compile(r"{FN_NAME_REGEX}", re.IGNORECASE)
    _READ_VAR_REGEX = re.compile(r"{READ_VAR_REGEX}", re.IGNORECASE)
    _REQUIRED_CALL_REGEX = re.compile(r"{REQUIRED_CALL_REGEX}", re.IGNORECASE)

    def _detect(self):
        results = []
        for c in self.contracts:
            if is_vendored_or_test_contract(c):
                continue
            for f in c.functions_and_modifiers_declared:
                if not self._FN_NAME_REGEX.search(f.name):
                    continue
                # Skip pure/view leaf helpers — they trivially "don't call the
                # required helper" because they don't call anything. See
                # SKILL_ISSUE #55.
                if is_leaf_helper(f):
                    continue

                # FP precision: a function already protected by an
                # initializer/reinitializer modifier, an access modifier, or
                # belonging to a contract whose constructor calls
                # _disableInitializers() is NOT an unguarded-initializer bug.
                if _has_guard_modifier(f):
                    continue
                if _constructor_disables_initializers(c):
                    continue

                # Check that the function reads at least one state var matching the regex
                reads_target = False
                for sv in f.state_variables_read:
                    if self._READ_VAR_REGEX.search(sv.name):
                        reads_target = True
                        break
                if not reads_target:
                    continue

                # Check for the required internal/high-level call (presence = safe)
                has_required_call = False
                for ic in f.internal_calls:
                    callee = ic.function if hasattr(ic, "function") else ic
                    callee_name = getattr(callee, "name", "") or ""
                    if self._REQUIRED_CALL_REGEX.search(callee_name):
                        has_required_call = True
                        break
                if not has_required_call:
                    for hc_tuple in f.high_level_calls:
                        hc = hc_tuple[1] if isinstance(hc_tuple, tuple) else hc_tuple
                        callee_name = (
                            getattr(hc.function, "name", "") if hasattr(hc, "function") else ""
                        ) or ""
                        if self._REQUIRED_CALL_REGEX.search(callee_name):
                            has_required_call = True
                            break

                if has_required_call:
                    continue

                info = [
                    f,
                    f" — {DETECTOR_NAME}: reads `{{{{}}}}`-matching state but does not call a `{REQUIRED_CALL_REGEX}` guard. ",
                    f"Ported from {SOURCE}. See reference/bug_patterns_observed.md.",
                ]
                res = self.generate_result(info)
                results.append(res)
        return results
