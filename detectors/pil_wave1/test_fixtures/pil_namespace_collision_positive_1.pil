// Positive fixture 1: column `selector` declared in both Adder and Multiplier namespaces.
namespace Adder(2**16);
    col commit a;
    col commit b;
    col commit selector;
    selector * (a + b - a) = 0;

namespace Multiplier(2**16);
    col commit x;
    col commit y;
    col commit selector;    // collision: same name as Adder.selector
    selector * (x * y - x) = 0;
