// Negative fixture 1: all column names are unique across namespaces — no finding.
namespace Adder(2**16);
    col commit adder_a;
    col commit adder_b;
    col commit adder_selector;
    adder_selector * (adder_a + adder_b - adder_a) = 0;

namespace Multiplier(2**16);
    col commit mult_x;
    col commit mult_y;
    col commit mult_selector;
    mult_selector * (mult_x * mult_y - mult_x) = 0;
