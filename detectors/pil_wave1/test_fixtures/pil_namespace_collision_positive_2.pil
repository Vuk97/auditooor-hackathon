// Positive fixture 2: column `is_last` appears in three different namespaces.
namespace StateTransition(2**20);
    col commit state;
    col commit is_last;
    is_last * (1 - is_last) = 0;

namespace Padding(2**20);
    col commit pad_val;
    col commit is_last;    // collision with StateTransition.is_last
    is_last * pad_val = 0;

namespace Finalize(2**20);
    col commit output;
    col commit is_last;    // second collision
    is_last * output = output;
